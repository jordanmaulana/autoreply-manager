# --- Django ---
SECRET_KEY=
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Database (Postgres + pgvector, required) ---
# Dev: `make db` starts a pgvector container matching these defaults. Compose: POSTGRES_HOST=postgres.
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=localhost
# make db maps the container to 15432 (5432/5433 are often taken by native Postgres)
POSTGRES_PORT=15432

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=

# --- Mayar (payments) ---
MAYAR_API_KEY=
MAYAR_WEBHOOK_TOKEN=
MAYAR_BASE_URL=https://api.mayar.id/hl/v1
PAYMENT_REDIRECT_URL=http://localhost:5173/

# --- OpenAI (RAG embeddings + auto-reply generation) ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Meta / social platforms ---
# Instagram: Meta dashboard > your app > Instagram > API setup with Instagram login
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Threads: separate "Threads API" app type in Meta dashboard > Use cases > Threads API
THREADS_APP_ID=
THREADS_APP_SECRET=
# WhatsApp: app secret of the Meta app owning the WABA (Settings > Basic)
WHATSAPP_APP_SECRET=
# Any random string; paste the same value in the webhook config on the Meta dashboard
META_WEBHOOK_VERIFY_TOKEN=
# Threads has no reply webhooks at MVP: poll interval for manage.py poll_threads
THREADS_POLL_SECONDS=60

# --- URLs ---
# SITE_URL must be a public HTTPS URL for Meta webhooks/OAuth callbacks (use ngrok in dev)
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Frontend build args ---
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=
